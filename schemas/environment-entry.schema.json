{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://m-standard.local/schemas/environment-entry.schema.json",
  "title": "m-standard environment entry",
  "description": "One environment entry (per spec §5.7, §6.3). v1.0 captures device I/O parameters from YDB; lock/transaction/error-handling semantics are covered by entries in commands.tsv and intrinsic-special-variables.tsv. AnnoStd does not contribute (BL-009).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "concept",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "concept": {
      "type": "string",
      "const": "environment"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "kind",
          "standard_status",
          "in_anno",
          "in_ydb"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "description": "Subkind within the environment family — e.g. device-parameter."
          },
          "summary": {
            "type": "string"
          },
          "standard_status": {
            "type": "string",
            "enum": [
              "ansi",
              "ydb-extension"
            ]
          },
          "in_anno": {
            "type": "boolean"
          },
          "in_ydb": {
            "type": "boolean"
          },
          "ydb_section": {
            "type": "string"
          },
          "anno_section": {
            "type": "string"
          }
        }
      }
    }
  }
}
