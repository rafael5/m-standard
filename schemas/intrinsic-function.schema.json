{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://m-standard.local/schemas/intrinsic-function.schema.json",
  "title": "m-standard intrinsic function entry",
  "description": "One M intrinsic function in the integrated layer (per spec §5.2, §6.3).",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "concept",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1"
    },
    "concept": {
      "type": "string",
      "const": "intrinsic-functions"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "canonical_name",
          "standard_status",
          "in_anno",
          "in_ydb"
        ],
        "properties": {
          "canonical_name": {
            "type": "string",
            "pattern": "^\\$",
            "description": "Canonical function name including the leading $ (e.g. $ASCII)."
          },
          "abbreviation": {
            "type": "string",
            "description": "Standard abbreviation including $ (e.g. $A). May be empty for AnnoStd-only entries with BNF rendering."
          },
          "format": {
            "type": "string"
          },
          "standard_status": {
            "type": "string",
            "enum": [
              "ansi",
              "ydb-extension"
            ]
          },
          "in_anno": {
            "type": "boolean"
          },
          "in_ydb": {
            "type": "boolean"
          },
          "anno_section": {
            "type": "string"
          },
          "ydb_section": {
            "type": "string"
          },
          "conflict_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  }
}
